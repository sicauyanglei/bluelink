<Window x:Class="BluetoothFileServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="BluLink - 文件传输服务端" Height="600" Width="650"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <DockPanel>
    <Grid Margin="20" DockPanel.Dock="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo/Icon -->
                <Border Grid.Column="0"
                        Background="{StaticResource PrimaryBrush}"
                        CornerRadius="8"
                        Width="48" Height="48"
                        Margin="0,0,16,0">
                    <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6M12,8A4,4 0 0,0 8,12A4,4 0 0,0 12,16A4,4 0 0,0 16,12A4,4 0 0,0 12,8Z"
                          Fill="White"
                          Stretch="Uniform"
                          Width="24" Height="24"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="BluLink 文件传输服务端"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="在同一WiFi网络下快速传输文件"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Connection Status -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12"
                             Fill="{StaticResource TextMutedBrush}"
                             Margin="0,0,8,0"/>
                    <TextBlock x:Name="ConnectionStatusText"
                               Text="未连接"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bluetooth Section -->
        <GroupBox Grid.Row="1" Header="蓝牙">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Control Buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button x:Name="StartBluetoothButton"
                            Content="启动蓝牙"
                            Style="{StaticResource ModernButtonStyle}"
                            Width="100" Height="36"
                            Click="StartBluetooth_Click"/>
                    <Button x:Name="StopBluetoothButton"
                            Content="停止蓝牙"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="100" Height="36"
                            Margin="10,0,0,0"
                            IsEnabled="False"
                            Click="StopBluetooth_Click"/>
                </StackPanel>

                <!-- Device Info -->
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceVariantBrush}"
                        CornerRadius="6"
                        Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="本机蓝牙: "
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock x:Name="BluetoothDeviceName"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" ("
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="BluetoothDeviceAddress"
                                       Foreground="{StaticResource AccentCyanBrush}"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=")"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Ellipse x:Name="BluetoothStatusIndicator"
                                     Width="10" Height="10"
                                     Fill="{StaticResource TextMutedBrush}"
                                     Margin="0,0,6,0"/>
                            <TextBlock x:Name="BluetoothStatus"
                                       Foreground="{StaticResource AccentCyanBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Connected device name -->
                <TextBlock x:Name="ConnectedDeviceName"
                           Foreground="{StaticResource SuccessBrush}"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"/>
            </Grid>
        </GroupBox>

        <!-- TCP Section -->
        <GroupBox Grid.Row="2" Header="TCP (同一WiFi下使用)">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Control Row -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="StartTcpButton"
                            Grid.Column="0"
                            Content="启动TCP"
                            Style="{StaticResource ModernButtonStyle}"
                            Width="100" Height="36"
                            Click="StartTcp_Click"/>
                    <Button x:Name="StopTcpButton"
                            Grid.Column="1"
                            Content="停止TCP"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="100" Height="36"
                            Margin="10,0,0,0"
                            IsEnabled="False"
                            Click="StopTcp_Click"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="端口: "
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TcpPortTextBox"
                                 Width="80" Height="36"
                                 Text="9000"
                                 VerticalContentAlignment="Center"
                                 TextAlignment="Center"
                                 FontSize="13"
                                 Padding="12,8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="AutoStartCheckBox"
                                  Content="开机自启动"
                                  VerticalAlignment="Center"
                                  Click="AutoStart_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Status Row -->
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceVariantBrush}"
                        CornerRadius="6"
                        Padding="12,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="状态: "
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Ellipse x:Name="TcpStatusIndicator"
                                     Width="10" Height="10"
                                     Fill="{StaticResource TextMutedBrush}"
                                     Margin="0,0,8,0"/>
                            <TextBlock x:Name="TcpStatus"
                                       Foreground="{StaticResource AccentCyanBrush}"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TcpConnectedDeviceName"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Shared Directory Section -->
        <GroupBox Grid.Row="3" Header="共享目录">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Path Selection Row -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="下载目录:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="SharePathTextBox"
                             Grid.Row="1" Grid.Column="0"
                             Text="E:\"
                             FontSize="13"
                             Padding="8,6"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Row="1" Grid.Column="1"
                            Content="浏览"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="60" Height="32"
                            Margin="6,0,0,0"
                            Click="Browse_Click"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="上传目录:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="UploadPathTextBox"
                             Grid.Row="1" Grid.Column="3"
                             Text="E:\upload"
                             FontSize="13"
                             Padding="8,6"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Row="1" Grid.Column="4"
                            Content="浏览"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="60" Height="32"
                            Margin="6,0,0,0"
                            Click="BrowseUploadPath_Click"/>
                </Grid>

                <!-- File List -->
                <ListBox x:Name="FileListBox"
                         Grid.Row="2"
                         Style="{StaticResource ModernListBoxStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"
                                      Fill="{StaticResource TextSecondaryBrush}"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <!-- Transfer Log Section -->
        <GroupBox Grid.Row="4" Height="100">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="传输日志" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="复制日志" Margin="10,0,0,0" Padding="8,2" FontSize="11"
                            Click="CopyLog_Click"/>
                </StackPanel>
                <ListBox x:Name="LogListBox"
                         Grid.Row="1"
                         Style="{StaticResource ModernListBoxStyle}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       FontFamily="Consolas"
                                       Margin="2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>
    </Grid>
    </DockPanel>
</Window>
